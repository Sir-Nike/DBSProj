<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.collegequiz.controller.TeacherAddQuestionController">
    <top>
        <VBox spacing="12" styleClass="page-shell">
            <VBox spacing="6" styleClass="hero-panel">
                <Label text="Add Question" styleClass="hero-title"/>
                <Label fx:id="teacherLabel" text="Teacher"/>
            </VBox>
            <HBox spacing="10">
                <Button text="Back" onAction="#handleBack" styleClass="button secondary"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="14" styleClass="card">
            <Label text="Question Details" styleClass="section-title"/>
            <Label text="Quiz" styleClass="field-label"/>
            <ComboBox fx:id="quizCombo"/>
            <Label text="Question Text" styleClass="field-label"/>
            <TextArea fx:id="questionTextArea" prefRowCount="2"/>
            <Label text="Marks" styleClass="field-label"/>
            <TextField fx:id="marksField"/>
            <GridPane hgap="10" vgap="10">
                <children>
                    <Label text="Option 1" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="option1Field" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <RadioButton fx:id="correct1" text="Correct" GridPane.rowIndex="0" GridPane.columnIndex="2"/>

                    <Label text="Option 2" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="option2Field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    <RadioButton fx:id="correct2" text="Correct" GridPane.rowIndex="1" GridPane.columnIndex="2"/>

                    <Label text="Option 3" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="option3Field" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    <RadioButton fx:id="correct3" text="Correct" GridPane.rowIndex="2" GridPane.columnIndex="2"/>

                    <Label text="Option 4" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="option4Field" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    <RadioButton fx:id="correct4" text="Correct" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                </children>
            </GridPane>
            <Button text="Save Question" onAction="#handleSave" maxWidth="Infinity"/>
        </VBox>
    </center>
</BorderPane>
