<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.collegequiz.controller.AdminLoginController" styleClass="auth-root">
    <top>
        <HBox alignment="CENTER_RIGHT" styleClass="topbar">
            <Button text="Toggle Theme" onAction="#handleToggleTheme" styleClass="button-ghost"/>
        </HBox>
    </top>
    <center>
        <VBox alignment="TOP_CENTER" spacing="18" styleClass="auth-center">
            <VBox spacing="6" alignment="CENTER" styleClass="auth-brand">
                <Label text="Admin Login" styleClass="title-xxl"/>
                <Label text="Use your admin credentials." styleClass="subtitle-muted"/>
            </VBox>
            <VBox spacing="14" maxWidth="420" styleClass="form-card auth-form login-shell">
                <Label text="Administrator" styleClass="section-title"/>
                <Label text="Username" styleClass="field-label"/>
                <TextField fx:id="adminUsernameField" promptText="admin"/>
                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="adminPasswordField" promptText="admin123"/>
                <Button text="Login" onAction="#handleLogin" maxWidth="Infinity" styleClass="dashboard-action"/>
                <Button text="Back" onAction="#handleBack" maxWidth="Infinity" styleClass="button-ghost"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
