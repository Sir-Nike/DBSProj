<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.collegequiz.controller.TeacherCreateQuizController">
    <top>
        <VBox spacing="12" styleClass="page-shell">
            <VBox spacing="6" styleClass="hero-panel">
                <Label text="Create Quiz" styleClass="hero-title"/>
                <Label fx:id="teacherLabel" text="Teacher"/>
            </VBox>
            <HBox spacing="10">
                <Button text="Back" onAction="#handleBack" styleClass="button secondary"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="14" maxWidth="520" styleClass="card" BorderPane.alignment="CENTER">
            <Label text="Quiz Details" styleClass="section-title"/>
            <Label text="Subject" styleClass="field-label"/>
            <ComboBox fx:id="subjectCombo"/>
            <Label text="Quiz Title" styleClass="field-label"/>
            <TextField fx:id="quizTitleField"/>
            <Label text="Duration (minutes)" styleClass="field-label"/>
            <TextField fx:id="durationField"/>
            <Label text="Quiz Date" styleClass="field-label"/>
            <DatePicker fx:id="quizDatePicker"/>
            <Button text="Save Quiz" onAction="#handleSave" maxWidth="Infinity"/>
        </VBox>
    </center>
</BorderPane>
