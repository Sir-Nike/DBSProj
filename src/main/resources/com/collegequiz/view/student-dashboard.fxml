<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.collegequiz.controller.StudentDashboardController" styleClass="screen-root">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="topbar">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Student Dashboard" styleClass="title-xxl"/>
                <Label fx:id="studentNameLabel" text="Student" styleClass="subtitle-muted"/>
                <Label fx:id="registrationLabel" text="Reg No" styleClass="subtitle-muted"/>
            </VBox>
            <Button text="Refresh" onAction="#handleRefresh" styleClass="button-ghost"/>
            <Button text="Start Quiz" onAction="#handleStartQuiz" styleClass="dashboard-action"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="button-ghost"/>
            <Button text="Toggle Theme" onAction="#handleToggleTheme" styleClass="button-ghost"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="16" styleClass="dashboard-layout">
            <HBox spacing="12" styleClass="summary-strip">
                <VBox spacing="4" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label text="Department" styleClass="stat-label"/>
                    <Label fx:id="departmentLabel" text="Department" styleClass="stat-value"/>
                </VBox>
                <VBox spacing="4" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label text="Available Quizzes" styleClass="stat-label"/>
                    <Label fx:id="availableCountLabel" text="0" styleClass="stat-value"/>
                </VBox>
                <VBox spacing="4" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label text="Published Results" styleClass="stat-label"/>
                    <Label fx:id="resultCountLabel" text="0" styleClass="stat-value"/>
                </VBox>
            </HBox>
            <HBox spacing="16" VBox.vgrow="ALWAYS">
                <VBox spacing="10" styleClass="panel-card" HBox.hgrow="ALWAYS">
                    <Label text="Available Quizzes" styleClass="section-title"/>
                    <TableView fx:id="quizTable" prefHeight="320" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="quizTitleColumn" text="Title" prefWidth="260"/>
                            <TableColumn fx:id="subjectColumn" text="Subject" prefWidth="240"/>
                            <TableColumn fx:id="durationColumn" text="Minutes" prefWidth="90"/>
                            <TableColumn fx:id="marksColumn" text="Marks" prefWidth="90"/>
                            <TableColumn fx:id="publishedColumn" text="Published" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
                <VBox spacing="10" styleClass="panel-card" HBox.hgrow="ALWAYS">
                    <Label text="Published Results" styleClass="section-title"/>
                    <TableView fx:id="resultTable" prefHeight="320" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="resultQuizTitleColumn" text="Quiz Title" prefWidth="280"/>
                            <TableColumn fx:id="resultScoreColumn" text="Score" prefWidth="100"/>
                            <TableColumn fx:id="resultPercentColumn" text="Percent" prefWidth="100"/>
                            <TableColumn fx:id="resultTimeColumn" text="Submitted At" prefWidth="220"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
