<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.collegequiz.controller.TeacherHomeController">
    <center>
        <VBox alignment="CENTER" spacing="18" styleClass="page-shell">
            <VBox alignment="CENTER_LEFT" spacing="6" styleClass="hero-panel">
                <Label text="Teacher Home" styleClass="hero-title"/>
                <Label fx:id="teacherLabel" text="Teacher"/>
                <Label text="Choose one task at a time. Each screen is kept intentionally compact." styleClass="hero-subtitle"/>
            </VBox>

            <VBox spacing="12" maxWidth="420" styleClass="card">
                <Button text="Create Subject" onAction="#handleCreateSubject" maxWidth="Infinity"/>
                <Button text="Create Quiz" onAction="#handleCreateQuiz" maxWidth="Infinity"/>
                <Button text="Add Question" onAction="#handleAddQuestion" maxWidth="Infinity"/>
                <Button text="Review / Publish Results" onAction="#handleReviewResults" maxWidth="Infinity"/>
                <Button text="Logout" onAction="#handleLogout" styleClass="button secondary" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
