<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.collegequiz.controller.StudentLoginController">
    <center>
        <VBox alignment="CENTER" spacing="16" styleClass="screen-root">
            <VBox spacing="6" styleClass="hero-card">
                <Label text="Student Login" styleClass="title-xxl"/>
                <Label text="Use your 9-digit registration number and password." styleClass="subtitle-muted"/>
            </VBox>
            <VBox spacing="12" maxWidth="360" styleClass="form-card">
                <Label text="Registration Number" styleClass="field-label"/>
                <TextField fx:id="studentRegNoField" promptText="9-digit registration number"/>
                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="studentPasswordField" promptText="Student password"/>
                <Button text="Login" onAction="#handleLogin" maxWidth="Infinity"/>
                <Button text="Back" onAction="#handleBack" styleClass="button-ghost" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
